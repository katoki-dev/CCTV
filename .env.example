# CASS - Camera Alert Surveillance System
# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
DEBUG=False

# Database
DATABASE_PATH=database.db

# ==================== Email Alert Configuration ====================
# Email method: Uses Flask-Mail (preferred) with automatic fallback to SMTP
# Flask-Mail provides better reliability and error handling

# Enable/disable email alerts
EMAIL_ENABLED=True

# SMTP Server Settings (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Email Credentials
# For Gmail: Use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=devkatoki@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Sender Information
EMAIL_FROM_ADDRESS=devkatoki@gmail.com
EMAIL_FROM_NAME=CASS Alert System

# Recipients (comma-separated list)
EMAIL_RECIPIENT_LIST=katoki.dev@gmail.com

# ==================== WhatsApp Alert Configuration ====================
# WhatsApp phone numbers (comma-separated, with country code)
WHATSAPP_PHONE_NUMBERS=+919685338175,+916364731668

# CallMeBot API (Optional - for browser-less WhatsApp)
# Get your API key from: https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=
CALLMEBOT_PHONE=

# YOLO Configuration
YOLO_DEVICE=0  # Use 0 for GPU, cpu for CPU-only mode

# ==================== Alert Settings ====================
ALERT_COOLDOWN_SECONDS=60
MAX_ALERTS_PER_HOUR=20
CROWD_THRESHOLD=5
CROWD_ALERT_COOLDOWN_SECONDS=120

# SMTP Email Configuration (for alerts with video clip attachments)
# Gmail users: Enable 2FA and create an App Password at:
# https://myaccount.google.com/apppasswords
# Use the App Password (16 characters) in SMTP_PASSWORD, not your regular password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=CASS Surveillance System

# Note: Video clips (~1-5MB) are attached to alert emails
# Some email providers have attachment size limits (Gmail allows 25MB)

# Logging
LOG_LEVEL=INFO
